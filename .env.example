# Copy this file to .env and fill in real values.
# .env itself is gitignored — never commit secrets.

# GitHub Personal Access Token. ONLY used by build/deploy tooling
# (e.g. a release script or a serverless feedback proxy if/when we add one).
# The static landing page does NOT use it — the Support buttons open the
# GitHub issue page directly with prefilled query params, no auth needed.
GITHUB_TOKEN=
